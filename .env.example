# wattwise-core — example environment (COPY to your secret manager, NOT to a
# committed file). The engine reads secrets from the environment at startup
# (BOOT-R4); it does not read .env files at runtime. This example documents the
# variable NAMES and shapes only — never commit real values.

# --- REQUIRED: the canonical store DSN (portable: SQLite / PostgreSQL / MariaDB) ---
# SQLite (dev):       sqlite+aiosqlite:////var/lib/wattwise/wattwise.sqlite
# PostgreSQL (prod):  postgresql+asyncpg://wattwise:PASS@db:5432/wattwise
# MariaDB:            mysql+aiomysql://wattwise:PASS@db:3306/wattwise
WATTWISE_DATABASE_DSN=

# --- REQUIRED in staging/production: envelope-encryption root key (base64, 32 bytes) ---
WATTWISE_ENCRYPTION_ROOT_KEY=

# --- REQUIRED in staging/production: token signing key (random, >=32 bytes) ---
WATTWISE_TOKEN_SIGNING_KEY=

# --- LLM provider (OpenAI-compatible). Key is a secret; base_url/model are config ---
WATTWISE_LLM_API_KEY=
WATTWISE_AGENT__BASE_URL=https://openrouter.ai/api/v1
WATTWISE_AGENT__MODEL=deepseek/deepseek-chat

# --- app/runtime ---
WATTWISE_APP__ENVIRONMENT=production
WATTWISE_API__PORT=8000

# --- optional: point at an operator config file overlaid on packaged defaults ---
# WATTWISE_CONFIG_FILE=/etc/wattwise/config.toml
