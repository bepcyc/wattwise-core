# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.so

# uv / venv
.venv/
venv/

# test / coverage
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
junit*.xml

# local data / scratch (the engine targets ONLY its own isolated store)
*.sqlite
*.sqlite3
*.db
local.db
/data/
/.scratch/

# secrets — NEVER commit. Service/infra secrets come from env/secret-manager
# at startup (BOOT-R4); the build agent never reads the operator's .env (TASK §5).
.env
.env.*
!.env.example
*.pem
*.key

# the one-time legacy->canonical migration is out-of-repo + gitignored (RUN-R14)
/scripts/legacy_migration*.py
/migration_local/

# generated typed client (built in CI; artifact, not source-of-truth)
/clients/ts/node_modules/

# local-only architecture diagrams (kept on disk, intentionally NOT published —
# they carry internal program structure; see CONTRIBUTING §8 documentation hygiene)
/ARCHITECTURE_DIAGRAM.md
/ARCHITECTURE_DIAGRAM_SIMPLIFIED.md
/ARCHITECTURE_DIAGRAM_SIMPLIFIED_4DUMMIES.md

# local-only development progress tracker (timestamped; never published)
/PROGRESS.md

# local-only session handoff (never published)
/HANDOFF.md

# local-only skill-generated handoffs (session-handoff skill; carry internal
# program structure + session notes — never published)
/.claude/

# OS
.DS_Store
